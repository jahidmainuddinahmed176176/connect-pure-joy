generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Destination {
  id          Int      @id @default(autoincrement())
  name        String
  country     String
  description String?
  visited     Boolean  @default(false)
  createdAt   DateTime @default(now())
}